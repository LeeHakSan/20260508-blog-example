{{> layout/header}}

<div class="flex-grow-1 d-flex align-items-center justify-content-center">
    <div class="text-center px-3 py-5">
        <div class="error-code mb-2">500</div>
        <h4 class="fw-bold text-dark mb-2">서버 오류가 발생했습니다</h4>
        <p class="text-muted mb-4">{{msg}}</p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="/" class="btn btn-primary">
                <i class="fa-solid fa-house me-1"></i>메인 페이지
            </a>
            <a href="javascript:location.reload()" class="btn btn-outline-secondary">
                <i class="fa-solid fa-rotate-right me-1"></i>새로고침
            </a>
        </div>
    </div>
</div>

{{> layout/footer}}
