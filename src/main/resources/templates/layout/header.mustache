<!DOCTYPE html>
<html lang="ko">

<head>
    <title>MyBlog</title>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body {
            background-color: #f5f5f7;
        }
        .navbar {
            padding: 0.8rem 0;
        }
        .navbar-brand {
            font-weight: 700;
            font-size: 1.2rem;
            letter-spacing: -0.3px;
        }
        .nav-link {
            font-size: 0.875rem;
            padding: 0.4rem 0.8rem !important;
            border-radius: 6px;
            transition: background 0.15s;
        }
        .navbar-dark .nav-link:hover {
            background: rgba(255,255,255,0.08);
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            transition: box-shadow 0.2s, transform 0.2s;
        }
        .card-header {
            background-color: #fff;
            border-bottom: 1px solid #f0f0f0;
            border-radius: 12px 12px 0 0 !important;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 0.95rem;
        }
        .card-body {
            padding: 1.5rem;
        }
        .form-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: #555;
            margin-bottom: 0.3rem;
            letter-spacing: 0.01em;
        }
        .form-control, .form-select {
            border-color: #e0e0e0;
            border-radius: 8px;
            padding: 0.55rem 0.85rem;
            font-size: 0.9rem;
            background-color: #fafafa;
        }
        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 3px rgba(13,110,253,0.1);
            background-color: #fff;
        }
        .form-control[readonly], .form-control:disabled {
            background-color: #f0f0f0;
            color: #888;
        }
        .btn {
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0.48rem 1.1rem;
        }
        .page-link {
            border-radius: 6px !important;
            margin: 0 2px;
            color: #555;
        }
        .page-item.active .page-link {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }
        .board-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1) !important;
        }
        .auth-wrapper {
            max-width: 420px;
            margin: 0 auto;
            padding: 3rem 1rem;
        }
        .page-wrapper {
            max-width: 780px;
            margin: 0 auto;
            padding: 2.5rem 1rem;
        }
        .error-code {
            font-size: 6rem;
            font-weight: 800;
            line-height: 1;
            color: #dee2e6;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">
<nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm">
    <div class="container">
        <a class="navbar-brand" href="/"><i class="fa-solid fa-feather-pointed me-2 text-primary"></i>MyBlog</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
            <ul class="navbar-nav ms-auto">
                {{#sessionUser}}
                    <li class="nav-item">
                        <a class="nav-link" href="/board/save-form"><i class="fa-solid fa-pen fa-sm me-1"></i>글쓰기</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/user/update-form"><i class="fa-solid fa-user fa-sm me-1"></i>회원정보보기</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/logout"><i class="fa-solid fa-right-from-bracket fa-sm me-1"></i>로그아웃</a>
                    </li>
                {{/sessionUser}}
                {{^sessionUser}}
                    <li class="nav-item">
                        <a class="nav-link" href="/join-form"><i class="fa-solid fa-user-plus fa-sm me-1"></i>회원가입</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/login-form"><i class="fa-solid fa-right-to-bracket fa-sm me-1"></i>로그인</a>
                    </li>
                {{/sessionUser}}
            </ul>
        </div>
    </div>
</nav>
