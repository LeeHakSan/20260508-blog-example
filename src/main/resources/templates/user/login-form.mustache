{{> layout/header}}

<div class="flex-grow-1">
    <div class="auth-wrapper">
        <div class="text-center mb-4">
            <i class="fa-solid fa-right-to-bracket fa-2x text-primary mb-2"></i>
            <h5 class="fw-bold mb-0">로그인</h5>
            <p class="text-muted small mt-1">계속하려면 로그인하세요</p>
        </div>
        <div class="card">
            <div class="card-body">
                <form action="/login" method="post">
                    <div class="mb-3">
                        <label class="form-label">아이디</label>
                        <input type="text" class="form-control" placeholder="아이디를 입력하세요" name="username" value="ssar">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">비밀번호</label>
                        <input type="password" class="form-control" placeholder="비밀번호를 입력하세요" name="password" value="1234">
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fa-solid fa-right-to-bracket me-1"></i>로그인
                    </button>
                </form>
            </div>
        </div>
        <p class="text-center text-muted small mt-3">
            계정이 없으신가요? <a href="/join-form" class="text-primary text-decoration-none fw-semibold">회원가입</a>
        </p>
    </div>
</div>

{{> layout/footer}}
