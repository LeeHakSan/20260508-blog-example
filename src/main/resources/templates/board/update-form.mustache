{{> layout/header}}
<div class="flex-grow-1">
    <div class="page-wrapper">
        <div class="card">
            <div class="card-header">
                <i class="fa-solid fa-pen me-2 text-warning"></i>글 수정
            </div>
            <div class="card-body">
                <form action="/board/{{id}}/update" method="post">
                    <div class="mb-3">
                        <label class="form-label">작성자</label>
                        <input type="text" name="username" class="form-control"
                               placeholder="작성자" value="{{board.username}}" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">제목</label>
                        <input type="text" name="title" class="form-control" placeholder="제목을 입력하세요"
                               value="{{board.title}}">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">내용</label>
                        <textarea name="content" rows="10" class="form-control" placeholder="내용을 입력하세요">{{board.content}}</textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-warning"><i class="fa-solid fa-floppy-disk me-1"></i>수정 완료</button>
                        <a href="/board/{{id}}" class="btn btn-outline-secondary">취소</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}
