{{> layout/header}}
<div class="flex-grow-1">
    <div class="page-wrapper">
        <div class="card">
            <div class="card-header">
                <i class="fa-solid fa-pen-to-square me-2 text-primary"></i>새 글 작성
            </div>
            <div class="card-body">
                <form action="/board/save" method="post">
                    <div class="mb-3">
                        <label class="form-label">제목</label>
                        <input type="text" name="title" class="form-control" placeholder="제목을 입력하세요">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">내용</label>
                        <textarea name="content" rows="10" class="form-control" placeholder="내용을 입력하세요"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary"><i class="fa-solid fa-floppy-disk me-1"></i>글쓰기 완료</button>
                        <a href="/board/list" class="btn btn-outline-secondary">취소</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}
